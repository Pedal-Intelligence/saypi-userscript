{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["node", "chrome", "firefox-webext-browser", "vitest/globals"]
  },
  "include": [
    "src/**/*",
    "entrypoints/**/*",
    "test/**/*",
    "scripts/**/*",
    "wxt.config.ts",
    ".wxt/wxt.d.ts"
  ],
  "exclude": ["public", "dist"]
}
